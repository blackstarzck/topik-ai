{
  "name": "topik-ai-admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "lint": "set ESLINT_USE_FLAT_CONFIG=false&& eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "sync:tinymce": "node ./scripts/copy-tinymce-assets.mjs",
    "postinstall": "node ./scripts/copy-tinymce-assets.mjs"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@tinymce/tinymce-react": "^6.3.0",
    "antd": "5.28.0",
    "axios": "^1.8.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.30.0",
    "tinymce": "^8.3.2",
    "zustand": "4.5.7"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "@vitejs/plugin-react": "4.3.1",
    "eslint": "8.57.1",
    "eslint-plugin-react-hooks": "4.6.2",
    "typescript": "5.6.3",
    "vite": "5.4.10"
  }
